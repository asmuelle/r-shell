{
  "enabledPlugins": {
    "ecc@ecc": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/qa/pre_write_guard.sh",
            "statusMessage": "Guarding oversized writes (>800 lines)"
          }
        ]
      }
    ],
    "PostToolUse": [{}],
    "Stop": [{}]
  }
}
